public class Ejer3ArreglosMatriz {

public static void main(String[] args) { Scanner teclado = new Scanner(System.in); int[] numeros = new int[15];

for (int i = 0; i < numeros.length; i++) { System.out.print("Ingrese el numero entero " + (i + 1) + ": "); numeros[i] = Integer.parseInt(teclado.nextLine());
}

int mayor = numeros[0]; int menor = numeros[0]; int posicionMayor = 0; int posicionMenor = 0;

for (int i = 0; i < numeros.length; i++) { if (numeros[i] > mayor) {
mayor = numeros[i]; posicionMayor = i + 1 ;
}
if (numeros[i] < menor) { menor = numeros[i]; posicionMenor = i + 1;
}
}

System.out.println("\n--- Resultados ---");
System.out.println("Numero mayor: " + mayor + " (posicion " + posicionMayor + ")"); System.out.println("Numero menor: " + menor + " (posicion " + posicionMenor + ")");
}
}
