public class Ejer1ArreglosMatriz {

public static void main(String[] args) { Scanner teclado = new Scanner(System.in);
int[] numeros = new int[10];

for (int i = 0; i < numeros.length; i++) {
System.out.print("Ingrese el numero en la posicion " + i + ": "); numeros[i] = Integer.parseInt(teclado.nextLine());
}

System.out.println("\n--- Valores almacenados ---"); for (int i = 0; i < numeros.length; i++) {
System.out.println("Posicion " + i + ": " + numeros[i]);
}
}
}
