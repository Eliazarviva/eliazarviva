public class Ejer2ArreglosMatriz {

public static void main(String[] args) { Scanner teclado = new Scanner(System.in);
double[] numeros = new double[10]; double suma = 0;

for (int i = 0; i < numeros.length; i++) { System.out.print("Ingrese el numero real " + (i + 1) + ": "); numeros[i] = Double.parseDouble(teclado.nextLine());
suma += numeros[i];
}

double promedio = suma / numeros.length;

System.out.println("\n--- Resultados ---"); System.out.println("Suma total: " + suma); System.out.println("Promedio: " + promedio);
}
}
